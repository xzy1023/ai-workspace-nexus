{
  "nexus-hooks": {
    "PreToolUse": [
      {
        "matcher": "write_file|edit_file|replace|create_file|patch|write_to_file|replace_file_content|multi_replace_file_content",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/run-hook.cmd check-git-branch",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "write_file|edit_file|replace|create_file|patch|run_command|execute_command|write_to_file|replace_file_content|multi_replace_file_content",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/run-hook.cmd inject-plan",
            "timeout": 5
          }
        ]
      }
    ],
    "PreInvocation": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/run-hook.cmd inject-plan",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/run-hook.cmd check-gate",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
